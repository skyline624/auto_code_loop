{
  "Cycle": {
    "CycleIntervalMs": 60000,
    "MaxHypothesesPerCycle": 3,
    "DryRun": false,
    "TargetProjectPath": ".",
    "MaxCycles": null,
    "InteractiveMode": false
  },
  "ClaudeCode": {
    "Executable": "claude",
    "DefaultModel": "claude-sonnet-4-6",
    "MaxTokens": 4096,
    "TimeoutMs": 300000,
    "ContextFileLimit": 10,
    "Temperature": 0.7,
    "DebugMode": false
  },
  "ProjectDetection": {
    "AutoDetect": true,
    "DetectionTimeoutMs": 5000
  },
  "Testing": {
    "TestProjectPath": "./tests",
    "BenchmarkIterations": 100,
    "TestTimeoutSeconds": 300,
    "TestTimeoutMs": 300000,
    "MaxRegressionPercent": 5.0,
    "AutoDetectFramework": true,
    "FailFastOnErrors": true
  },
  "GitHub": {
    "Owner": "CHANGE_ME",
    "Repository": "CHANGE_ME",
    "DefaultBranch": "main"
  },
  "LocalGit": {
    "RepositoryPath": ".",
    "UserName": "AutoLoop Bot",
    "UserEmail": "autoloop@system.local"
  },
  "Hypothesis": {
    "LookbackCycles": 10,
    "MaxHypotheses": 5,
    "MinConfidenceThreshold": 0.3
  },
  "Evaluation": {
    "MinPerformanceImprovementPercent": 5.0,
    "MaxAllowedRegressionPercent": 1.0,
    "StatisticalSignificanceAlpha": 0.05,
    "MinCohensD": 0.2,
    "RequireBootstrapCIPositive": true,
    "RequireAllUnitTestsPassing": true
  },
  "Monitoring": {
    "PrometheusPort": 9090,
    "MaxCpuPercent": 90.0,
    "MaxConsecutiveFailures": 3
  },
  "Storage": {
    "JournalsPath": "./storage/journals",
    "AuditTrailPath": "./storage/audit.jsonl",
    "BaselinePath": "./storage/baseline.json",
    "ChangeTrackerPath": "./storage/changes.jsonl",
    "MemoryPath": "./storage/memory"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/autoloop-.jsonl",
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  }
}